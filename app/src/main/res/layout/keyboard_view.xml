<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:background="#E3E5E8">

    <!-- Tool Bar / Suggestion Bar -->
    <FrameLayout
        android:id="@+id/toolbar_container"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:background="#E3E5E8">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp">

            <!-- Chevron -->
            <ImageButton
                android:id="@+id/btn_toolbar_chevron"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_chevron_right"
                android:contentDescription="Expand Toolbar" />

            <!-- Suggestions / Expanded Toolbar content -->
            <HorizontalScrollView
                android:id="@+id/toolbar_expanded_scroll"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scrollbars="none"
                android:visibility="gone"
                android:fillViewport="true">
                
                <LinearLayout
                    android:id="@+id/toolbar_expanded_content"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/suggestion_content"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:visibility="visible">
                
                <TextView
                     android:id="@+id/suggestion_1"
                     android:layout_width="0dp"
                     android:layout_height="match_parent"
                     android:layout_weight="1"
                     android:gravity="center"
                     android:text=""
                     android:textColor="#333333"
                     android:padding="8dp"
                     android:textSize="14sp"
                     android:background="?android:attr/selectableItemBackground"
                     android:clickable="true" />
                     
                <View
                     android:layout_width="1dp"
                     android:layout_height="match_parent"
                     android:layout_marginVertical="8dp"
                     android:background="#CCCCCC" />
                     
                <TextView
                     android:id="@+id/suggestion_2"
                     android:layout_width="0dp"
                     android:layout_height="match_parent"
                     android:layout_weight="1"
                     android:gravity="center"
                     android:text=""
                     android:textColor="#333333"
                     android:padding="8dp"
                     android:textSize="14sp"
                     android:background="?android:attr/selectableItemBackground"
                     android:clickable="true" />
                     
                <View
                     android:layout_width="1dp"
                     android:layout_height="match_parent"
                     android:layout_marginVertical="8dp"
                     android:background="#CCCCCC" />
                     
                <TextView
                     android:id="@+id/suggestion_3"
                     android:layout_width="0dp"
                     android:layout_height="match_parent"
                     android:layout_weight="1"
                     android:gravity="center"
                     android:text=""
                     android:textColor="#333333"
                     android:padding="8dp"
                     android:textSize="14sp"
                     android:background="?android:attr/selectableItemBackground"
                     android:clickable="true" />
            </LinearLayout>

            <!-- Pinned Keys -->
            <LinearLayout
                android:id="@+id/toolbar_pinned"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <ImageButton
                    android:id="@+id/btn_toolbar_enter"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_enter"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:contentDescription="Next Line" />
                
                <ImageButton
                    android:id="@+id/btn_toolbar_paste"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_clipboard"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:contentDescription="Paste Menu" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- Content Area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="260dp">
        
        <!-- Custom Drawn Keyboard Grid -->
        <com.example.keyboard.KeyboardView
            android:id="@+id/keyboard_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:background="#E3E5E8" />
            
        <!-- Clipboard History List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/clipboard_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#E3E5E8"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout>
